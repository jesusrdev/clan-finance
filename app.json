{
  "expo": {
    "name": "clan-finance",
    "slug": "clan-finance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "clanfinance",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF5E6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clanfinance.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF5E6"
      },
      "package": "com.clanfinance.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "react-native-edge-to-edge"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}